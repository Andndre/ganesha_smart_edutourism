  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes: [
    { name: 'cultural_objects_category_index', columns: [category] }
    { name: 'cultural_objects_created_at_index', columns: [created_at] }
  ]
}

Table cultural_stories {
  id integer [primary key, not null]
  cultural_object_id bigint unsigned [not null, ref: > cultural_objects.id]
  title varchar(255) [not null]
  content text [not null]
  story_type varchar(20) [not null, note: 'enum: history, philosophy, value']
  "order" integer [default: 0]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes: [
    { name: 'cultural_stories_cultural_object_id_order_index', columns: [cultural_object_id, "order"] }
  ]
}



