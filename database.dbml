// DBML Schema — Website Wisata Desa Penglipuran
// Generated from live MySQL schema via laravel-boost

Project website_wisata_penglipuran {
  database_type: 'MySQL'
  Note: 'Smart Sustainable Edutourism Platform for Desa Wisata Penglipuran'
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

Table users {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null]
  email varchar(255) [not null, unique]
  google_id varchar(255)
  email_verified_at timestamp
  password varchar(255) [not null]
  role enum [not null, note: 'tourist | umkm_owner | admin | ticket_officer']
  phone varchar(255)
  nationality varchar(255)
  preferred_language varchar(10) [default: 'id']
  avatar_path varchar(255)
  remember_token varchar(100)
  created_at timestamp
  updated_at timestamp
}

Table sessions {
  id varchar(255) [primary key]
  user_id bigint [ref: > users.id]
  ip_address varchar(45)
  user_agent text
  payload longtext [not null]
  last_activity int [not null]
}

Table password_reset_tokens {
  email varchar(255) [primary key]
  token varchar(255) [not null]
  created_at timestamp
}

Table personal_access_tokens {
  id bigint [primary key, not null, increment]
  tokenable_type varchar(255) [not null]
  tokenable_id bigint [not null]
  name text [not null]
  token varchar(64) [not null, unique]
  abilities text
  last_used_at timestamp
  expires_at timestamp
  created_at timestamp
  updated_at timestamp
}

Table push_subscriptions {
  id bigint [primary key, not null, increment]
  subscribable_type varchar(255) [not null, note: 'morph to users']
  subscribable_id bigint [not null]
  endpoint varchar(500) [not null]
  public_key varchar(255)
  auth_token varchar(255)
  content_encoding varchar(255)
  created_at timestamp
  updated_at timestamp
}

Table notifications {
  id char(36) [primary key]
  type varchar(255) [not null]
  notifiable_type varchar(255) [not null]
  notifiable_id bigint [not null]
  data text [not null]
  read_at timestamp
  created_at timestamp
  updated_at timestamp
}

// ============================================
// CULTURAL OBJECTS & STORIES
// ============================================

Table cultural_objects {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  slug varchar(255) [not null, unique]
  short_description varchar(255) [note: 'JSON translatable: {en, id}']
  description text [not null, note: 'JSON translatable: {en, id}']
  category enum [not null, note: 'temple | house | craft | tradition']
  historical_images json
  audio_narration_paths json [note: 'locale-keyed: {en: path, id: path}']
  created_at timestamp
  updated_at timestamp

  indexes {
    (category) [name: 'cultural_objects_category_index']
    (created_at) [name: 'cultural_objects_created_at_index']
  }
}

Table cultural_stories {
  id bigint [primary key, not null, increment]
  cultural_object_id bigint [not null, ref: > cultural_objects.id]
  title varchar(255) [not null, note: 'JSON translatable: {en, id}']
  content text [not null, note: 'JSON translatable: {en, id}']
  story_type enum [not null, note: 'history | philosophy | value']
  order int [default: 0]
  created_at timestamp
  updated_at timestamp

  indexes {
    (cultural_object_id, order) [name: 'cultural_stories_cultural_object_id_order_index']
  }
}

Table cultural_object_quizzes {
  id bigint [primary key, not null, increment]
  cultural_object_id bigint [not null, ref: > cultural_objects.id]
  question text [not null, note: 'JSON translatable: {en, id}']
  option_a varchar(255) [not null]
  option_b varchar(255) [not null]
  option_c varchar(255) [not null]
  option_d varchar(255) [not null]
  correct_option char(1) [not null, note: 'a | b | c | d']
  created_at timestamp
  updated_at timestamp
}

// ============================================
// AR MODELS
// ============================================

Table ar_models {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  ar_marker_id varchar(255) [unique]
  ar_marker_patt_path varchar(255) [note: 'PATT file for AR.js/A-Frame']
  map_location_id bigint [ref: > map_locations.id]
  description text [note: 'JSON translatable: {en, id}']
  model_3d_path varchar(255) [note: 'GLB/GLTF for Android/WebAR']
  model_3d_usdz_path varchar(255) [note: 'USDZ for iOS AR Quick Look']
  audio_narration_paths json [note: 'locale-keyed: {en: path, id: path}']
  thumbnail_path varchar(255)
  created_at timestamp
  updated_at timestamp
}

// ============================================
// MAPS & FACILITIES
// ============================================

Table map_locations {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  category enum [not null, note: 'cultural | umkm | facility | emergency | accessibility']
  locationable_type varchar(255) [not null, note: 'morph: CulturalObject | UmkmProfile | Facility | ArModel']
  locationable_id bigint [not null]
  latitude decimal(10,8) [not null]
  longitude decimal(11,8) [not null]
  is_accessible tinyint(1) [default: 1]
  accessibility_notes text [note: 'JSON translatable: {en, id}']
  created_at timestamp
  updated_at timestamp

  indexes {
    (category) [name: 'map_locations_category_index']
    (is_accessible) [name: 'map_locations_is_accessible_index']
    (locationable_type, locationable_id) [name: 'map_locations_locationable_index']
  }
}

Table facilities {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  type varchar(255) [not null, note: 'toilet | parking | info_center | etc.']
  description text [note: 'JSON translatable: {en, id}']
  is_active tinyint(1) [default: 1]
  created_at timestamp
  updated_at timestamp
}

Table capacity_zones {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null]
  zone_identifier varchar(255) [not null, unique]
  polygon_coordinates json [not null, note: 'Geofence polygon [[lat,lng],...]']
  max_capacity int [not null]
  warning_threshold int [default: 70, note: 'percent']
  critical_threshold int [default: 90, note: 'percent']
  current_count int [default: 0]
  is_active tinyint(1) [default: 1]
  created_at timestamp
  updated_at timestamp
}

// ============================================
// TOUR ROUTES & EDUTOURISM
// ============================================

Table tour_routes {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  description text [note: 'JSON translatable: {en, id}']
  difficulty enum [not null, note: 'easy | moderate | challenging']
  estimated_duration_minutes int [not null]
  distance_meters int [not null]
  is_active tinyint(1) [default: 1]
  created_at timestamp
  updated_at timestamp
}

Table tour_route_points {
  id bigint [primary key, not null, increment]
  tour_route_id bigint [not null, ref: > tour_routes.id]
  locationable_type varchar(255) [not null, note: 'morph: CulturalObject | Facility | UmkmProfile']
  locationable_id bigint [not null]
  order int [not null]
  estimated_visit_minutes int [default: 15]
  storytelling_content text [note: 'JSON translatable: {en, id}']
  created_at timestamp
  updated_at timestamp

  indexes {
    (tour_route_id, order) [name: 'tour_route_points_order_index']
  }
}

Table route_sessions {
  id bigint [primary key, not null, increment]
  user_id bigint [ref: > users.id]
  guest_token varchar(255) [note: 'for unauthenticated users']
  tour_route_id bigint [not null, ref: > tour_routes.id]
  current_point_id bigint [ref: > tour_route_points.id]
  points_completed int [default: 0]
  total_score int [default: 0]
  status enum [not null, note: 'active | completed | abandoned']
  created_at timestamp
  updated_at timestamp
}

// ============================================
// EVENTS & TOUR PACKAGES
// ============================================

Table events {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  slug varchar(255) [not null, unique]
  description text [note: 'JSON translatable: {en, id}']
  category enum [not null, note: 'cultural | culinary | workshop | ceremony']
  start_datetime datetime [not null]
  end_datetime datetime [not null]
  location_name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  is_free tinyint(1) [default: 0]
  price decimal(12,2)
  max_participants int
  current_participants int [default: 0]
  registration_url varchar(255)
  created_at timestamp
  updated_at timestamp
}

Table tour_packages {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  slug varchar(255) [not null, unique]
  description text [note: 'JSON translatable: {en, id}']
  inclusions json [note: 'JSON translatable per-item: [{en, id}]']
  exclusions json [note: 'JSON translatable per-item: [{en, id}]']
  price decimal(12,2) [not null]
  duration_hours decimal(4,1) [not null]
  max_capacity int [not null]
  min_capacity int [default: 1]
  images json
  is_active tinyint(1) [default: 1]
  created_at timestamp
  updated_at timestamp
}

Table reservations {
  id bigint [primary key, not null, increment]
  user_id bigint [ref: > users.id]
  guest_name varchar(255) [not null]
  guest_email varchar(255)
  tour_package_id bigint [ref: > tour_packages.id]
  reservation_type enum [not null, note: 'package | custom_tour | event']
  scheduled_date date [not null]
  party_size int [not null]
  total_amount decimal(12,2) [not null]
  status enum [default: 'pending', note: 'pending | confirmed | completed | cancelled | refunded']
  payment_status enum [default: 'unpaid', note: 'unpaid | paid | refunded']
  payment_method varchar(255)
  payment_reference varchar(255)
  qr_code varchar(255) [not null, unique]
  checked_in_at timestamp
  checked_in_by bigint [ref: > users.id]
  cancelled_at timestamp
  cancelled_by bigint [ref: > users.id]
  cancellation_type varchar(255)
  cancellation_note text
  created_at timestamp
  updated_at timestamp

  indexes {
    (status) [name: 'reservations_status_index']
    (payment_status) [name: 'reservations_payment_status_index']
    (scheduled_date) [name: 'reservations_scheduled_date_index']
    (scheduled_date, status) [name: 'reservations_scheduled_date_status_index']
    (checked_in_at) [name: 'reservations_checked_in_at_index']
  }
}

// ============================================
// UMKM (LOCAL MICRO BUSINESSES)
// ============================================

Table umkm_profiles {
  id bigint [primary key, not null, increment]
  user_id bigint [ref: > users.id]
  owner_name varchar(255) [not null]
  business_name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  slug varchar(255) [not null, unique]
  description text [note: 'JSON translatable: {en, id}']
  rating decimal(2,1) [default: 0]
  is_active tinyint(1) [default: 1]
  recommendation_count int [default: 0, note: 'for fair distribution algorithm']
  created_at timestamp
  updated_at timestamp
}

Table umkm_product_categories {
  id bigint [primary key, not null, increment]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  slug varchar(255) [not null, unique]
  description text [note: 'JSON translatable: {en, id}']
  price decimal(12,2)
  unit varchar(50)
  image_path varchar(255)
  model_3d_path varchar(255)
  model_3d_usdz_path varchar(255)
  created_at timestamp
  updated_at timestamp
}

Table umkm_products {
  id bigint [primary key, not null, increment]
  umkm_profile_id bigint [not null, ref: > umkm_profiles.id]
  umkm_product_category_id bigint [ref: > umkm_product_categories.id]
  name varchar(255) [not null, note: 'JSON translatable: {en, id}']
  slug varchar(255) [not null, unique]
  description text [note: 'JSON translatable: {en, id}']
  price decimal(12,2) [not null]
  stock int [default: 0]
  unit varchar(50) [default: 'pcs']
  images json
  is_active tinyint(1) [default: 1]
  created_at timestamp
  updated_at timestamp
}

// ============================================
// USER ACTIVITY
// ============================================

Table user_favorites {
  id bigint [primary key, not null, increment]
  user_id bigint [not null, ref: > users.id]
  favoritable_type varchar(255) [not null, note: 'morph: CulturalObject | Event | TourPackage | UmkmProfile']
  favoritable_id bigint [not null]
  created_at timestamp
  updated_at timestamp

  indexes {
    (user_id, favoritable_type, favoritable_id) [unique, name: 'user_favorites_unique']
  }
}

Table user_visits {
  id bigint [primary key, not null, increment]
  user_id bigint [not null, ref: > users.id]
  visitable_type varchar(255) [not null, note: 'morph: CulturalObject']
  visitable_id bigint [not null]
  route_session_id bigint [ref: > route_sessions.id]
  visited_at timestamp [not null]
  created_at timestamp
  updated_at timestamp
}

Table visitor_logs {
  id bigint [primary key, not null, increment]
  session_id varchar(255) [not null]
  user_id bigint [ref: > users.id]
  event_type enum [not null, note: 'page_view | feature_use | location_visit | purchase']
  event_data json
  latitude decimal(10,8)
  longitude decimal(11,8)
  device_type varchar(255)
  browser varchar(255)
  nationality varchar(255)
  logged_at datetime [not null]
  created_at timestamp
  updated_at timestamp

  indexes {
    (session_id) [name: 'visitor_logs_session_id_index']
    (logged_at) [name: 'visitor_logs_logged_at_index']
    (event_type) [name: 'visitor_logs_event_type_index']
  }
}

Table feedbacks {
  id bigint [primary key, not null, increment]
  user_id bigint [ref: > users.id]
  reservation_id bigint [ref: > reservations.id]
  feedback_type enum [not null, note: 'general | cultural | service | facility | umkm']
  rating int [not null]
  comment text
  photos json
  admin_response text
  created_at timestamp
  updated_at timestamp
}

// ============================================
// SYSTEM & SETTINGS
// ============================================

Table village_settings {
  id bigint [primary key, not null, increment]
  open_time time [not null]
  close_time time [not null]
  created_at timestamp
  updated_at timestamp
}

Table weather_reports {
  id bigint [primary key, not null, increment]
  temperature decimal(4,1) [not null]
  condition varchar(255) [not null]
  weather_code int [not null]
  humidity int [not null]
  wind_speed decimal(5,2) [not null]
  created_at timestamp
  updated_at timestamp
}
