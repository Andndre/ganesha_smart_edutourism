// DBML Schema for Ganesha Smart Edutourism
// Auto-generated from migrations

Project ganesha_smart_edutourism {
  database_type: 'SQLite'
  Note: 'Smart Edutourism Application for Ganesha Temple Tourism'
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

Table users {
  id integer [primary key, not null]
  name varchar(255) [not null]
  email varchar(255) [not null, unique]
  email_verified_at timestamp [nullable]
  password varchar(255) [not null]
  role varchar(20) [default: 'tourist', note: 'enum: tourist, umkm_owner, admin']
  phone varchar(20) [nullable]
  nationality varchar(50) [nullable]
  preferred_language varchar(10) [default: 'id']
  avatar_path varchar(255) [nullable]
  remember_token varchar(100) [nullable]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes: [
    { name: 'users_email_unique', columns: [email], unique: true }
  ]
}

Table personal_access_tokens {
  id integer [primary key, not null]
  tokenable_type varchar(255) [not null]
  tokenable_id bigint unsigned [not null]
  name varchar(255) [not null]
  token varchar(64) [not null, unique]
  abilities text [nullable]
  last_used_at timestamp [nullable]
  expires_at timestamp [nullable]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes: [
    { name: 'personal_access_tokens_tokenable_type_tokenable_id_index', columns: [tokenable_type, tokenable_id] }
  ]
}

Table password_reset_tokens {
  email varchar(255) [primary key, not null]
  token varchar(255) [not null]
  created_at timestamp [nullable]
}

Table sessions {
  id varchar(255) [primary key, not null]
  user_id bigint unsigned [nullable]
  ip_address varchar(45) [nullable]
  user_agent text [nullable]
  payload longtext [not null]
  last_activity integer [not null]

  indexes: [
    { name: 'sessions_user_id_index', columns: [user_id] }
    { name: 'sessions_last_activity_index', columns: [last_activity] }
  ]
}

