// ============================================
// RELATIONSHIPS
// ============================================

// Cultural Objects relationships
Ref: cultural_stories.cultural_object_id > cultural_objects.id [delete: cascade]

// UMKM relationships
Ref: umkm_profiles.user_id > users.id [delete: set null]
Ref: umkm_products.umkm_profile_id > umkm_profiles.id [delete: cascade]

// Map & Tour relationships
Ref: tour_route_points.tour_route_id > tour_routes.id [delete: cascade]

// Reservation relationships
Ref: reservations.user_id > users.id [delete: set null]
Ref: reservations.tour_package_id > tour_packages.id [delete: set null]

// Learning relationships
Ref: learning_contents.learning_module_id > learning_modules.id [delete: cascade]
Ref: learning_quizzes.learning_content_id > learning_contents.id [delete: cascade]
Ref: user_learning_progress.user_id > users.id [delete: cascade]
Ref: user_learning_progress.learning_module_id > learning_modules.id [delete: cascade]
Ref: user_learning_progress.last_content_id > learning_contents.id [delete: set null]

// Feedback relationships
Ref: feedbacks.user_id > users.id [delete: set null]
Ref: feedbacks.reservation_id > reservations.id [delete: set null]

// Visitor Log relationships
Ref: visitor_logs.user_id > users.id [delete: set null]