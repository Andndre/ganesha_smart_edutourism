flowchart TD
    %% Styling Colors
    classDef startEnd fill:#1b5e20,stroke:#fff,stroke-width:2px,color:#fff;
    classDef process fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px,color:#000;
    classDef decision fill:#fff3e0,stroke:#e65100,stroke-width:1px,color:#000;
    classDef system fill:#e3f2fd,stroke:#1565c0,stroke-width:1px,color:#000;

    Start([Buka Aplikasi Wisata]):::startEnd --> Auth{Pilih Akses}:::decision
    Auth -->|Login / Register / Google OAuth| UserDashboard[Dashboard Pengguna]:::process
    Auth -->|Tanpa Login| GuestPanel[Mode Tamu]:::process

    UserDashboard --> Home[Beranda — Cuaca & Info Desa]:::process
    GuestPanel --> Home

    %% ================= FASE 1: PRE-VISIT =================
    subgraph Fase1 ["Fase 1 — Persiapan & Pemesanan (Pre-Visit)"]
        direction TB
        Home --> CekEvent[Lihat Event & Kalender Budaya]:::process
        Home --> Explore[Eksplorasi Peta Interaktif]:::process
        Home --> LihatPaket[Lihat Paket Tour]:::process

        CekEvent & Explore & LihatPaket --> PesanTiket{Cara Pesan?}:::decision

        PesanTiket -->|Paket Tour Online| Reservasi[Booking Paket Tour]:::process
        PesanTiket -->|Walk-in On-site| WalkIn[Petugas Input Data Tamu]:::process

        Reservasi --> BayarMidtrans[Bayar via Midtrans Snap]:::process
        BayarMidtrans -->|Sukses| TiketDigital[E-Ticket + QR Code dikirim via Email]:::system
        BayarMidtrans -->|Gagal/Pending| TungguBayar[Status: unpaid — bisa repay]:::process
    end

    %% ================= FASE 2: ARRIVAL =================
    subgraph Fase2 ["Fase 2 — Kedatangan & Check-In"]
        direction TB
        TiketDigital --> StaffScan[Petugas Scan QR Tiket]:::process
        WalkIn --> StaffBayar[Petugas Proses Pembayaran Snap]:::process
        StaffBayar --> StaffScan

        StaffScan --> Validasi{QR Valid?}:::decision
        Validasi -->|Ya| CheckIn[Check-In — catat checked_in_at & by]:::system
        Validasi -->|Tidak| Tolak[Tolak / Cek Status Midtrans]:::process
    end

    CheckIn --> MulaiTour([Mulai Tour Desa Penglipuran]):::startEnd

    %% ================= FASE 3: ON-SITE & EDUTOURISM =================
    subgraph Fase3 ["Fase 3 — Smart Edutourism, Navigasi & AR (On-Site)"]
        direction TB
        MulaiTour --> PilihRute[Preview & Pilih Rute Edutourism]:::process
        PilihRute --> StartSession[Buat RouteSession — status: active]:::system
        StartSession --> Navigasi[Navigasi ke Titik Berikutnya]:::process

        Navigasi --> TibaDiTitik{Tiba di Titik?}:::decision

        %% Cultural Object branch
        TibaDiTitik -->|Objek Budaya| BukaAR[Buka AR Scanner]:::process
        BukaAR -->|Marker terdeteksi| TampilModel[Tampil Model 3D GLB/USDZ]:::process
        TampilModel --> AudioStory[Dengarkan Audio Storytelling]:::process
        AudioStory --> BacaCerita[Baca Cerita: Sejarah / Filosofi / Nilai]:::process

        %% Quiz branch
        TibaDiTitik -->|Pos Edutourism| Kuis[Jawab Kuis Budaya]:::process
        Kuis --> SkorUpdate[Update total_score di RouteSession]:::system

        BacaCerita & SkorUpdate --> RecordVisit[Catat UserVisit — visitable morph]:::system
        RecordVisit --> CekKapasitas[Cek Kapasitas Zona Berikutnya — Reverb WS]:::process

        CekKapasitas -->|Zona Normal| LanjutRute{Titik Berikutnya?}:::decision
        CekKapasitas -->|Zona Kritis| PeringatanZona[Tampil Peringatan Keramaian]:::process
        PeringatanZona --> LanjutRute

        LanjutRute -->|Ya| Navigasi
        LanjutRute -->|Selesai| SelesaiRute[Tandai RouteSession: completed]:::system
    end

    SelesaiRute --> KeUMKM([Lanjut ke Area UMKM]):::startEnd

    %% ================= FASE 4: UMKM =================
    subgraph Fase4 ["Fase 4 — Katalog & Belanja UMKM"]
        direction TB
        KeUMKM --> LihatKatalog[Lihat Katalog UMKM]:::process
        LihatKatalog --> Rekomendasi[Rekomendasi Adil via UmkmRecommendationService]:::system
        Rekomendasi --> MultiRoute[Multi-Route ke Beberapa Toko]:::process
        MultiRoute --> LihatProduk[Lihat Produk & Harga]:::process
    end

    %% ================= FASE 5: POST-VISIT =================
    subgraph Fase5 ["Fase 5 — Post-Visit"]
        direction TB
        LihatProduk --> Favorit[Tambah ke Favorit — UserFavorite morph]:::process
        Favorit --> Feedback[Isi Feedback & Rating]:::process
        Feedback --> AdminReply[Admin balas Feedback — opsional]:::system
    end

    Feedback --> Selesai([Selesai Kunjungan]):::startEnd

    %% ================= SISTEM BACKGROUND =================
    subgraph Background ["Proses Background & Real-Time"]
        direction LR
        WS[Laravel Reverb WebSocket]:::system
        QUEUE[Queue Worker]:::system
        CRON[Cron Jobs]:::system

        CRON -->|Tiap 10 menit saat share| WeatherUpdate[Update WeatherReport]:::system
        CRON -->|H-1 event| EventReminder[Kirim Pengingat Email Event]:::system
        CRON -->|Harian| TusCleanup[Cleanup TUS Upload Basi]:::system
        QUEUE --> ETicketMail[Kirim E-Ticket via Mail]:::system
        WS --> CrowdAlert[Broadcast CrowdAlertSent ke subscriber]:::system
        WS --> VisitorTracking[Broadcast VisitorLocationUpdated ke peta admin]:::system
    end
