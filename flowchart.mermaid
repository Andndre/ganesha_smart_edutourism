flowchart TD
    %% Styling Colors
    classDef startEnd fill:#1b5e20,stroke:#fff,stroke-width:2px,color:#fff;
    classDef process fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px,color:#000;
    classDef decision fill:#fff3e0,stroke:#e65100,stroke-width:1px,color:#000;
    classDef actor fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#000;

    Start([Mulai: Buka Aplikasi Wisata]):::startEnd --> Auth{Pilih Akses}:::decision
    Auth -->|Login / Register| UserDashboard[User / Profile Dashboard]:::process
    Auth -->|Guest Access| GuestPanel[Guest Mode / Offline Mode]:::process

    UserDashboard --> PusatInfo[Smart Tourism Information Center]:::process
    GuestPanel --> PusatInfo

    %% ================= FASE 1: PRE-VISIT =================
    subgraph Fase1 ["Fase 1: Persiapan & Pemesanan Tiket (Pre-Visit)"]
        direction TB
        PusatInfo --> CekEvent[Lihat Event & Cultural Calendar]:::process
        PusatInfo --> Explore[Eksplorasi Desa & Fasilitas]:::process
        
        CekEvent --> PesanTiket{Pilih Cara Pesan?}:::decision
        Explore --> PesanTiket
        
        PesanTiket -->|Paket Tour| Reservasi[Pilih & Booking Tour Package]:::process
        PesanTiket -->|Walk-in| WalkIn["Beli di Staff Ticketing (On-site)"]:::process
        
        Reservasi --> BayarTiket[Digital Payment via Midtrans]:::process
        BayarTiket --> TiketDigital[Terima E-Ticket & QR Code]:::process
    end

    %% ================= FASE 2: ARRIVAL =================
    subgraph Fase2 ["Fase 2: Kedatangan & Check-In"]
        direction TB
        TiketDigital --> StaffScan[Staff Memindai QR Code Tiket]:::process
        WalkIn --> StaffScan
        StaffScan --> Validasi[Validasi & Check-in Sukses]:::process
    end

    Validasi --> MulaiTour([Mulai Tour di Desa Penglipuran]):::startEnd

    %% ================= FASE 3: ON-SITE & EDUTOURISM =================
    subgraph Fase3 ["Fase 3: Smart Edutourism, Navigasi & AR (On-Site)"]
        direction TB
        MulaiTour --> PilihRute[Preview & Pilih Rute Edutourism]:::process
        PilihRute --> MulaiNavigasi["Mulai Rute (Smart Routing / Map)"]:::process
        
        MulaiNavigasi -.-> AksesOffline[Offline Mode Tersedia jika Sinyal Hilang]:::process
        
        MulaiNavigasi --> TibaDiTitik{Tiba di Titik / Objek}:::decision
        
        %% AR & Edukasi
        TibaDiTitik -->|Budaya/Objek| BukaAR["Buka AR Scanner (WebAR/iOS Quick Look)"]:::process
        BukaAR --> AudioStory[Dengarkan Audio Storytelling]:::process
        
        TibaDiTitik -->|Pos Edukasi| EduQuiz[Akses Materi Edukasi & Jawab Quiz]:::process
        
        AudioStory --> CekKapasitas[Cek Crowd/Capacity di Titik Berikutnya]:::process
        EduQuiz --> CekKapasitas
    end

    CekKapasitas --> LanjutTour{Lanjut Rute?}:::decision
    LanjutTour -->|Ya| MulaiNavigasi
    LanjutTour -->|Selesai / Belanja| KeUMKM([Lanjut ke Area Belanja UMKM]):::startEnd

    %% ================= FASE 4: UMKM & TRANSAKSI =================
    subgraph Fase4 ["Fase 4: UMKM & Marketplace"]
        direction TB
        KeUMKM --> ScanUMKM[Lihat Katalog / Multi-route UMKM]:::process
        ScanUMKM --> Rekomendasi[Dapat Rekomendasi UMKM]:::process
        Rekomendasi --> Marketplace[Lihat Produk dari UMKM Owner]:::process
        Marketplace --> BeliProduk[Transaksi / Pemesanan]:::process
    end

    %% ================= FASE 5: POST-VISIT =================
    subgraph Fase5 ["Fase 5: Evaluasi (Post-Visit)"]
        direction TB
        BeliProduk --> BeriFeedback[Isi Form Feedback & Rating]:::process
        BeriFeedback --> ProfileUpdate[Update Profile: Visited & Favorites]:::process
    end

    ProfileUpdate --> Selesai([Selesai Kunjungan]):::startEnd